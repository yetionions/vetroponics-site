# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Your Stripe secret key (sk_live_... or sk_test_... for testing)
STRIPE_SECRET_KEY=sk_live_your_secret_key_here

# The Stripe Price ID for the Custom Caps 5-Pack product
# Create this in your Stripe Dashboard under Products
STRIPE_PRICE_ID_CUSTOM=price_your_custom_caps_price_id_here

# The public URL of your deployed site (used for Stripe success/cancel redirects)
# Leave as http://localhost:3000 for local development
SITE_URL=https://yourdomain.com

# Port the Node.js server listens on (default: 3000)
PORT=3000
